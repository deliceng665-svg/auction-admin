{
  "version": 2,
  "builds": [
    {
      "src": "admin/dist/**",
      "use": "@vercel/static"
    },
    {
      "src": "server/**",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/server/index.js"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/admin/dist/index.html"
    }
  ]
}
