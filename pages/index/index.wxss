/* pages/index/index.wxss - 浅色主题 */
.container {
  min-height: 100vh;
  background-color: #F9FAFC;
  padding-bottom: 180rpx;
}

/* 顶部 Slogan */
.header-slogan {
  text-align: center;
  padding: 30rpx 32rpx 20rpx;
  font-size: 32rpx;
  font-weight: bold;
  color: #0D2B5B;
  background: linear-gradient(135deg, #EDF6FF 0%, #D6E8FF 100%);
}

/* 搜索栏 */
.search-bar {
  margin: 20rpx 32rpx;
  padding: 20rpx 24rpx;
  border-radius: 40rpx;
  background-color: #FFFFFF;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  color: #888888;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

/* 金刚区分类入口 */
.category-container {
  display: flex;
  justify-content: space-between;
  flex-wrap: wrap;
  padding: 24rpx 16rpx;
  gap: 16rpx;
}

.category-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 22%;
  padding: 16rpx 0;
}

.category-icon {
  width: 96rpx;
  height: 96rpx;
  margin-bottom: 8rpx;
  border-radius: 24rpx;
  background-color: #FFFFFF;
  padding: 12rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 40rpx;
}

.category-name {
  font-size: 24rpx;
  color: #333333;
}

/* 商品列表 */
.product-list {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 24rpx;
  padding: 32rpx;
}

.product-card {
  background-color: #FFFFFF;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

/* 商品图片容器 */
.product-image-wrap {
  position: relative;
  width: 100%;
  height: 280rpx;
  background-color: #EDF6FF;
}

.product-image {
  width: 100%;
  height: 280rpx;
}

/* 本地 emoji 占位图（无网络图片时显示） */
.product-image-placeholder {
  width: 100%;
  height: 280rpx;
  background: linear-gradient(135deg, #EDF6FF 0%, #D0E8FF 100%);
  display: flex;
  justify-content: center;
  align-items: center;
}

.placeholder-emoji {
  font-size: 100rpx;
  line-height: 1;
}

.product-info {
  padding: 20rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.product-title {
  font-weight: bold;
  font-size: 28rpx;
  color: #0D2B5B;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}

.product-prices {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.product-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.current-price {
  font-size: 28rpx;
  font-weight: bold;
  color: #0D2B5B;
}

.price {
  font-size: 22rpx;
  color: #888888;
}

.label {
  font-size: 20rpx;
  color: #FFFFFF;
  background-color: #FFA500;
  border-radius: 16rpx;
  padding: 4rpx 12rpx;
}

.countdown {
  font-size: 22rpx;
  color: #FFA500;
  font-weight: bold;
}

.countdown.urgent {
  color: #FF6B6B;
  animation: pulse 1s infinite;
}

@keyframes pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.6; }
}
