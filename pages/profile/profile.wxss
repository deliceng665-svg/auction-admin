/* pages/profile/profile.wxss - 浅色主题 */
.container {
  min-height: 100vh;
  background-color: #F9FAFC;
  padding-bottom: 180rpx;
}

/* 未登录 */
.login-tip {
  display: flex;
  justify-content: center;
  align-items: center;
  min-height: 100vh;
  background-color: #F9FAFC;
}

.login-content {
  text-align: center;
  padding: 60rpx;
}

.login-icon {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background-color: #E5EAF1;
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 80rpx;
  margin: 0 auto 32rpx;
}

.login-text {
  color: #666666;
  font-size: 28rpx;
  display: block;
  margin-bottom: 40rpx;
}

.btn-login {
  background: linear-gradient(135deg, #0D2B5B 0%, #1A4A8C 100%);
  color: #FFFFFF;
  border-radius: 40rpx;
  padding: 24rpx 80rpx;
  font-size: 28rpx;
  font-weight: bold;
  border: none;
}

/* 已登录 - 头部 */
.profile-header {
  background: linear-gradient(135deg, #EDF6FF 0%, #D6E8FF 100%);
  padding: 60rpx 32rpx 120rpx;
  text-align: center;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background-color: rgba(13, 43, 91, 0.1);
  margin: 0 auto 20rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 60rpx;
}

.user-name {
  color: #0D2B5B;
  font-size: 32rpx;
  font-weight: bold;
}

/* 收益卡片 */
.profit-card {
  background-color: #FFFFFF;
  margin: -80rpx 32rpx 32rpx;
  border-radius: 24rpx;
  padding: 40rpx 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.1);
  position: relative;
  z-index: 1;
}

.profit-title {
  color: #666666;
  font-size: 26rpx;
  text-align: center;
  margin-bottom: 20rpx;
}

.profit-amounts {
  display: flex;
  justify-content: space-around;
  margin-bottom: 32rpx;
}

.profit-amount-item {
  text-align: center;
}

.profit-label {
  color: #888888;
  font-size: 24rpx;
  display: block;
  margin-bottom: 8rpx;
}

.profit-value {
  font-size: 36rpx;
  font-weight: bold;
}

.profit-value.total {
  color: #0D2B5B;
}

.profit-value.available {
  color: #4CAF50;
}

.profit-value.frozen {
  color: #FFA500;
}

.btn-withdraw {
  width: 100%;
  background: linear-gradient(135deg, #0D2B5B 0%, #1A4A8C 100%);
  color: #FFFFFF;
  border-radius: 40rpx;
  padding: 24rpx;
  font-size: 28rpx;
  font-weight: bold;
  border: none;
}

/* Tab切换 */
.tab-header {
  display: flex;
  background-color: #FFFFFF;
  margin: 0 32rpx 16rpx;
  border-radius: 16rpx;
  overflow: hidden;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 24rpx;
  font-size: 28rpx;
  color: #666666;
  position: relative;
}

.tab-item.active {
  color: #0D2B5B;
  font-weight: bold;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 60rpx;
  height: 4rpx;
  background-color: #0D2B5B;
  border-radius: 2rpx;
}

/* 订单列表 */
.order-list {
  padding: 0 32rpx;
}

.order-card {
  background-color: #FFFFFF;
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.order-header {
  display: flex;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.product-thumb {
  width: 120rpx;
  height: 120rpx;
  border-radius: 12rpx;
  background-color: #F0F0F0;
}

.product-detail {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.order-title {
  color: #0D2B5B;
  font-size: 28rpx;
  font-weight: bold;
}

.product-price {
  color: #0D2B5B;
  font-size: 28rpx;
  font-weight: bold;
}

.deposit-info {
  color: #888888;
  font-size: 22rpx;
}

.order-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 16rpx;
  border-top: 1rpx solid #F0F0F0;
}

.order-status {
  font-size: 24rpx;
  padding: 8rpx 20rpx;
  border-radius: 8rpx;
}

.status-bidding {
  background-color: #E3F2FD;
  color: #0D2B5B;
}

.status-success {
  background-color: #E8F5E9;
  color: #4CAF50;
}

.status-failed {
  background-color: #FFEBEE;
  color: #FF6B6B;
}

.order-actions {
  display: flex;
  gap: 16rpx;
}

.btn-pay {
  background-color: #FFA500;
  color: #FFFFFF;
  border-radius: 20rpx;
  padding: 12rpx 24rpx;
  font-size: 24rpx;
  border: none;
}

.btn-detail {
  background-color: #F0F0F0;
  color: #666666;
  border-radius: 20rpx;
  padding: 12rpx 24rpx;
  font-size: 24rpx;
  border: none;
}

/* 收益明细 */
.profit-list {
  padding: 0 32rpx;
}

.profit-item {
  background-color: #FFFFFF;
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.profit-item-left {
  flex: 1;
}

.profit-source {
  color: #0D2B5B;
  font-size: 28rpx;
  font-weight: bold;
  display: block;
  margin-bottom: 8rpx;
}

.profit-date {
  color: #888888;
  font-size: 22rpx;
}

.profit-item-right {
  text-align: right;
}

.profit-item-right .profit-value {
  color: #FFA500;
  display: block;
  margin-bottom: 8rpx;
}

.profit-status {
  font-size: 22rpx;
}

.profit-status.frozen {
  color: #FFA500;
}

.profit-status.available {
  color: #4CAF50;
}

/* 空状态 */
.empty-tip {
  text-align: center;
  padding: 80rpx;
  color: #888888;
  font-size: 28rpx;
}
