/* pages/auction/auction.wxss - 浅色主题 */
.container {
  min-height: 100vh;
  background-color: #F9FAFC;
  padding-bottom: 180rpx;
}

/* 顶部Banner */
.banner {
  background: linear-gradient(135deg, #EDF6FF 0%, #D6E8FF 100%);
  padding: 30rpx;
  text-align: center;
}

.banner-text {
  color: #0D2B5B;
  font-size: 28rpx;
  font-weight: bold;
}

/* 竞拍列表 */
.auction-list {
  padding: 32rpx;
}

.auction-card {
  background-color: #FFFFFF;
  border-radius: 24rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.1);
}

/* 商品图片容器 */
.product-image-wrap {
  width: 100%;
  height: 320rpx;
}

.product-image {
  width: 100%;
  height: 320rpx;
}

/* emoji 占位图 */
.product-image-placeholder {
  width: 100%;
  height: 320rpx;
  background: linear-gradient(135deg, #EDF6FF 0%, #D0E8FF 100%);
  display: flex;
  justify-content: center;
  align-items: center;
}

.placeholder-emoji {
  font-size: 120rpx;
  line-height: 1;
}

.product-info {
  padding: 24rpx;
}

.product-title {
  color: #0D2B5B;
  font-size: 30rpx;
  font-weight: bold;
  display: block;
  margin-bottom: 16rpx;
}

.price-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.price-info {
  display: flex;
  align-items: baseline;
  gap: 16rpx;
}

.current-price {
  color: #0D2B5B;
  font-size: 36rpx;
  font-weight: bold;
}

.start-price {
  color: #888888;
  font-size: 24rpx;
}

.countdown {
  background-color: #F0F0F0;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
  color: #FFA500;
  font-size: 24rpx;
  font-weight: bold;
}

.countdown.urgent {
  background-color: #FFF3E0;
  color: #FF6B6B;
  animation: pulse 1s infinite;
}

@keyframes pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.6; }
}

.profit-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.profit-badge {
  color: #FFA500;
  font-size: 24rpx;
  font-weight: bold;
}

.bid-count {
  color: #888888;
  font-size: 24rpx;
}

/* 空状态 */
.empty {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 100rpx 0;
}

.empty-text {
  color: #888888;
  font-size: 28rpx;
}
