/* pages/category/category.wxss - 三级分类 */
.container {
  display: flex;
  min-height: 100vh;
  background-color: #F9FAFC;
  padding-bottom: 100rpx;
}

/* 左侧一级分类 */
.first-level {
  width: 200rpx;
  height: 100vh;
  background-color: #FFFFFF;
}

.first-level-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 28rpx 16rpx;
  border-bottom: 1rpx solid #F0F0F0;
  position: relative;
}

.first-level-item.active {
  background-color: #F9FAFC;
}

.first-level-item.active::before {
  content: '';
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 6rpx;
  height: 60rpx;
  background-color: #0D2B5B;
  border-radius: 0 4rpx 4rpx 0;
}

.first-level-icon {
  font-size: 40rpx;
  margin-bottom: 8rpx;
}

.first-level-name {
  font-size: 24rpx;
  color: #333333;
  text-align: center;
}

.first-level-item.active .first-level-name {
  color: #0D2B5B;
  font-weight: bold;
}

/* 右侧内容区 */
.right-content {
  flex: 1;
  height: 100vh;
  background-color: #F9FAFC;
  padding: 24rpx;
}

/* 二级分类 */
.second-level {
  background-color: #FFFFFF;
  border-radius: 16rpx;
  padding: 8rpx 0;
  margin-bottom: 24rpx;
}

.second-level-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 32rpx;
  border-bottom: 1rpx solid #F5F5F5;
}

.second-level-item:last-child {
  border-bottom: none;
}

.second-level-item.active {
  background-color: #FFF8F0;
}

.second-level-name {
  font-size: 28rpx;
  color: #333333;
}

.second-level-item.active .second-level-name {
  color: #0D2B5B;
  font-weight: bold;
}

.arrow {
  color: #CCCCCC;
  font-size: 32rpx;
}

/* 三级分类 */
.third-level {
  background-color: #FFFFFF;
  border-radius: 16rpx;
  padding: 24rpx;
}

.third-level-title {
  font-size: 26rpx;
  color: #888888;
  margin-bottom: 24rpx;
  margin-top: 24rpx;
}

.third-level-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.third-level-chip {
  background-color: #F5F5F5;
  border-radius: 24rpx;
  padding: 16rpx 28rpx;
  font-size: 24rpx;
  color: #333333;
}

.third-level-chip.active {
  background-color: #0D2B5B;
  color: #FFFFFF;
}
