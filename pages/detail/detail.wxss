/* pages/detail/detail.wxss - 浅色主题 */
.container {
  min-height: 100vh;
  background-color: #F9FAFC;
  padding-bottom: 200rpx;
}

/* 图片轮播 */
.image-swiper-wrap {
  position: relative;
}

.image-swiper {
  height: 640rpx;
}

.slide-image {
  width: 100%;
  height: 100%;
  background-color: #E5EAF1;
}

.image-indicator {
  position: absolute;
  bottom: 20rpx;
  right: 20rpx;
  background-color: rgba(0, 0, 0, 0.5);
  color: #FFFFFF;
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
}

/* 商品信息 */
.product-info-section {
  background-color: #FFFFFF;
  padding: 32rpx;
  margin-bottom: 16rpx;
}

.product-title {
  color: #0D2B5B;
  font-size: 32rpx;
  font-weight: bold;
  display: block;
  margin-bottom: 16rpx;
}

.product-desc {
  color: #666666;
  font-size: 26rpx;
  line-height: 1.6;
}

/* 竞拍信息 */
.auction-info {
  background-color: #FFFFFF;
  padding: 32rpx;
  margin-bottom: 16rpx;
}

.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #F0F0F0;
}

.info-row:last-child {
  border-bottom: none;
}

.info-label {
  color: #666666;
  font-size: 28rpx;
}

.info-value {
  color: #333333;
  font-size: 28rpx;
  font-weight: bold;
}

.current-price {
  color: #0D2B5B;
  font-size: 40rpx;
  font-weight: bold;
}

.profit-percent {
  color: #FFA500;
  font-size: 28rpx;
  font-weight: bold;
}

.countdown {
  color: #FFA500;
  font-size: 28rpx;
  font-weight: bold;
}

.countdown.urgent {
  color: #FF6B6B;
  animation: pulse 1s infinite;
}

@keyframes pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.6; }
}

/* 保证金状态 */
.deposit-status {
  background-color: #FFF3E0;
  padding: 24rpx 32rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.deposit-text {
  color: #FFA500;
  font-size: 26rpx;
}

.deposit-badge {
  background-color: #FFA500;
  color: #FFFFFF;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
}

.deposit-badge.paid {
  background-color: #4CAF50;
}

/* 出价记录 */
.bid-list {
  background-color: #FFFFFF;
  padding: 32rpx;
  margin-bottom: 16rpx;
}

.section-title {
  color: #0D2B5B;
  font-size: 30rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
}

.bid-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #F0F0F0;
}

.bid-item:last-child {
  border-bottom: none;
}

.bid-item.highlight {
  background-color: #FFF3E0;
  margin: 0 -16rpx;
  padding: 20rpx 16rpx;
  border-radius: 12rpx;
}

.bid-user {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.user-avatar {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background-color: #E5EAF1;
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 32rpx;
}

.user-name {
  color: #333333;
  font-size: 26rpx;
}

.rank-badge {
  background-color: #FFA500;
  color: #FFFFFF;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  font-size: 20rpx;
}

.bid-amount {
  text-align: right;
}

.bid-price {
  color: #0D2B5B;
  font-size: 28rpx;
  font-weight: bold;
  display: block;
}

.bid-profit {
  color: #FFA500;
  font-size: 22rpx;
}

.empty-records {
  text-align: center;
  padding: 40rpx;
  color: #888888;
  font-size: 26rpx;
}

/* 底部操作区 */
.bottom-action {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: #FFFFFF;
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.1);
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.bid-input-section {
  display: flex;
  flex-direction: column;
}

.bid-input {
  background-color: #F0F0F0;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  color: #333333;
}

.bid-error {
  color: #FF6B6B;
  font-size: 22rpx;
  margin-top: 8rpx;
}

.action-btns {
  display: flex;
  gap: 16rpx;
}

.deposit-btn {
  flex: 1;
  background: linear-gradient(135deg, #FFA500 0%, #FF8C00 100%);
  color: #FFFFFF !important;
  border-radius: 24rpx;
  padding: 24rpx;
  font-size: 28rpx;
  font-weight: bold;
  border: none;
  line-height: 1.2;
}

.bid-btn {
  flex: 1;
  background: linear-gradient(135deg, #0D2B5B 0%, #1A4A8C 100%);
  color: #FFFFFF !important;
  border-radius: 24rpx;
  padding: 24rpx;
  font-size: 32rpx;
  font-weight: bold;
  border: none;
  line-height: 1.2;
}

.bid-btn.ended {
  background-color: #CCCCCC;
}
